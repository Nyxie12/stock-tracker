# Finnhub API key (required for live market data, news, and heatmap)
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=

# SQLite database path (default: local file)
DATABASE_URL=sqlite+aiosqlite:///./stocktracker.db

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5174

# Minimum ms between tick broadcasts per symbol (default: 500)
TICK_THROTTLE_MS=500

# Enable debug endpoints like POST /api/debug/tick (default: true)
DEBUG=true
